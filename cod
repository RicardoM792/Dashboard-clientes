<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard Agrario</title>

    <!-- CSS -->
    <link rel="stylesheet" href="style.css">

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

    <header>
        <h1>Dashboard Agrario</h1>
    </header>

    <!-- Indicadores -->
    <section id="indicadores">
        <div class="indicador">
            <span class="label">Total Revisados</span>
            <span id="totalRevisados" class="valor">0</span>
        </div>
        <div class="indicador">
            <span class="label">Total Aprobados</span>
            <span id="totalAprobados" class="valor">0</span>
        </div>
        <div class="indicador">
            <span class="label">Total Negados</span>
            <span id="totalNegados" class="valor">0</span>
        </div>
    </section>

    <!-- Gráficas -->
    <section id="graficas">
        <canvas id="chartEstados"></canvas>
        <canvas id="chartAseguradoras"></canvas>
    </section>

    <!-- Tabla Principal -->
    <section id="tabla-contenedor">
        <table id="tablaDatos">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Aseguradora</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th>Valor</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </section>

    <!-- JS -->
    <script src="script.js"></script>
</body>
</html>
